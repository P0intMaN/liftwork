# syntax=docker/dockerfile:1.7
# ---------------------------------------------------------------------------
# Auto-generated by liftwork. To take full control, commit your own Dockerfile.
# language: node  package_manager: {{ package_manager | default("npm") }}
# ---------------------------------------------------------------------------
ARG NODE_VERSION={{ language_version | default("20") }}

FROM node:${NODE_VERSION}-alpine AS deps
WORKDIR /app
{% if package_manager == "pnpm" -%}
RUN corepack enable && corepack prepare pnpm@latest --activate
COPY package.json pnpm-lock.yaml ./
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --prod=false
{%- elif package_manager == "yarn" -%}
RUN corepack enable
COPY package.json yarn.lock ./
RUN --mount=type=cache,target=/root/.cache/yarn yarn install --frozen-lockfile
{%- else -%}
COPY package.json package-lock.json* ./
RUN --mount=type=cache,target=/root/.npm npm ci --include=dev
{%- endif %}

FROM node:${NODE_VERSION}-alpine AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
{% if build_command -%}
RUN {{ build_command }}
{%- else -%}
RUN npm run build --if-present
{%- endif %}

FROM node:${NODE_VERSION}-alpine AS runtime
WORKDIR /app
RUN addgroup --system --gid 1000 app \
 && adduser  --system --uid 1000 --ingroup app --shell /sbin/nologin app
ENV NODE_ENV=production
COPY --from=build --chown=app:app /app /app
USER 1000:1000
EXPOSE {{ port | default(3000) }}
{% if command -%}
CMD {{ command | tojson }}
{%- else -%}
CMD ["node", "."]
{%- endif %}
