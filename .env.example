# --- Liftwork local dev environment ---
# Copy to .env and adjust as needed.

LIFTWORK_ENV=dev
LIFTWORK_LOG_LEVEL=INFO

# Postgres (matches deploy/docker-compose.yaml)
LIFTWORK_DATABASE_URL=postgresql+asyncpg://liftwork:liftwork@localhost:5432/liftwork

# Redis (queue + pubsub)
LIFTWORK_REDIS_URL=redis://localhost:6379/0

# Auth (v1 single-tenant; OIDC is v2)
LIFTWORK_JWT_SECRET=change-me-in-prod-please-use-32-bytes-min
LIFTWORK_JWT_ALGORITHM=HS256
LIFTWORK_JWT_TTL_SECONDS=3600

# Container registry (v1: GHCR)
LIFTWORK_REGISTRY_HOST=ghcr.io
LIFTWORK_REGISTRY_USERNAME=
LIFTWORK_REGISTRY_TOKEN=

# GitHub webhook signing secret
LIFTWORK_GITHUB_WEBHOOK_SECRET=

# Telemetry
LIFTWORK_OTEL_ENABLED=true
LIFTWORK_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LIFTWORK_PROMETHEUS_PATH=/metrics

# Target k8s context (must exist in kubeconfig)
LIFTWORK_KUBE_CONTEXT=kind-kubedeploy-dev
