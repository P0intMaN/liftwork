# --- Liftwork local dev environment ---
# Copy to .env and adjust as needed.
#
# Convention: top-level fields use a single underscore.
# Nested fields use a DOUBLE underscore: LIFTWORK_<SECTION>__<FIELD>

LIFTWORK_ENV=dev
LIFTWORK_LOG_LEVEL=INFO

# API bind (8000 is reserved by the user's other FastAPI service)
LIFTWORK_API__HOST=0.0.0.0
LIFTWORK_API__PORT=7878

# Worker
LIFTWORK_WORKER__CONCURRENCY=4
LIFTWORK_WORKER__HEALTH_PORT=7879

# Postgres (matches deploy/docker-compose.yaml)
LIFTWORK_DATABASE__URL=postgresql+asyncpg://liftwork:liftwork@localhost:5432/liftwork
LIFTWORK_DATABASE__POOL_SIZE=10
LIFTWORK_DATABASE__MAX_OVERFLOW=5
LIFTWORK_DATABASE__ECHO=false

# Redis (queue + pubsub)
LIFTWORK_REDIS__URL=redis://localhost:6379/0

# Auth (v1 single-tenant; OIDC is v2)
LIFTWORK_JWT__SECRET=change-me-in-prod-please-use-32-bytes-min-please
LIFTWORK_JWT__ALGORITHM=HS256
LIFTWORK_JWT__TTL_SECONDS=3600

# Container registry (v1: GHCR)
LIFTWORK_REGISTRY__HOST=ghcr.io
LIFTWORK_REGISTRY__USERNAME=
LIFTWORK_REGISTRY__TOKEN=

# GitHub webhook signing secret
LIFTWORK_GITHUB__WEBHOOK_SECRET=

# Telemetry
LIFTWORK_TELEMETRY__OTEL_ENABLED=true
LIFTWORK_TELEMETRY__OTEL_EXPORTER_OTLP_ENDPOINT=
LIFTWORK_TELEMETRY__OTEL_SERVICE_NAME=liftwork
LIFTWORK_TELEMETRY__PROMETHEUS_PATH=/metrics

# Target k8s context (must exist in kubeconfig)
LIFTWORK_K8S__KUBE_CONTEXT=kind-kubedeploy-dev
LIFTWORK_K8S__IN_CLUSTER=false
