# --- Liftwork local dev environment ---
# Copy to .env and adjust as needed.
#
# Convention: top-level fields use a single underscore.
# Nested fields use a DOUBLE underscore: LIFTWORK_<SECTION>__<FIELD>
#
# IMPORTANT: do not leave optional integer fields blank — Pydantic Settings
# parses empty strings as values, not as "absent". Comment them out or
# delete instead.

LIFTWORK_ENV=dev
LIFTWORK_LOG_LEVEL=INFO

# API bind (8000 is reserved by another local FastAPI service)
LIFTWORK_API__HOST=0.0.0.0
LIFTWORK_API__PORT=7878

# Worker
LIFTWORK_WORKER__CONCURRENCY=4
LIFTWORK_WORKER__HEALTH_PORT=7879
# Executor selection: "mock" for unit tests + first-run dev (no k8s),
# "kind" for the real BuildKit-in-pod + k8s-server-side-apply path.
LIFTWORK_WORKER__EXECUTOR=mock
LIFTWORK_WORKER__BUILDER_NAMESPACE=liftwork
LIFTWORK_WORKER__BUILDER_SERVICE_ACCOUNT=liftwork-builder
LIFTWORK_WORKER__DEPLOY_FIELD_MANAGER=liftwork-controller

# Postgres (matches deploy/docker-compose.yaml)
LIFTWORK_DATABASE__URL=postgresql+asyncpg://liftwork:liftwork@localhost:5432/liftwork
LIFTWORK_DATABASE__POOL_SIZE=10
LIFTWORK_DATABASE__MAX_OVERFLOW=5
LIFTWORK_DATABASE__ECHO=false

# Redis (queue + pubsub)
LIFTWORK_REDIS__URL=redis://localhost:6379/0

# Auth (v1 single-tenant; OIDC is v2)
LIFTWORK_JWT__SECRET=change-me-in-prod-please-use-32-bytes-min-please
LIFTWORK_JWT__ALGORITHM=HS256
LIFTWORK_JWT__TTL_SECONDS=3600

# Container registry. For dev e2e against the in-cluster registry:2,
# set host=registry.liftwork.svc.cluster.local:5000 and insecure=true.
LIFTWORK_REGISTRY__HOST=ghcr.io
LIFTWORK_REGISTRY__INSECURE=false
# LIFTWORK_REGISTRY__USERNAME=P0intMaN
# LIFTWORK_REGISTRY__TOKEN=ghp_xxxxxxxxxxxx

# GitHub App (register at https://github.com/settings/apps then fill these)
# Webhook secret is the only required field for the receiver to function.
LIFTWORK_GITHUB__WEBHOOK_SECRET=change-me-webhook-secret
# LIFTWORK_GITHUB__APP_ID=12345
# LIFTWORK_GITHUB__PRIVATE_KEY="-----BEGIN PRIVATE KEY-----..."
# LIFTWORK_GITHUB__INSTALLATION_ID=99999

# First-run admin (only seeded if BOTH are set and no users exist).
# Use a real email TLD — email-validator rejects .local and other reserved names.
LIFTWORK_BOOTSTRAP__ADMIN_EMAIL=admin@example.com
LIFTWORK_BOOTSTRAP__ADMIN_PASSWORD=change-me-now

# Telemetry
LIFTWORK_TELEMETRY__OTEL_ENABLED=true
# LIFTWORK_TELEMETRY__OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LIFTWORK_TELEMETRY__OTEL_SERVICE_NAME=liftwork
LIFTWORK_TELEMETRY__PROMETHEUS_PATH=/metrics

# Target k8s context (must exist in kubeconfig)
LIFTWORK_K8S__KUBE_CONTEXT=kind-kubedeploy-dev
LIFTWORK_K8S__IN_CLUSTER=false
